# Neon — copie do Console (Connect → pooled + direct)
# https://neon.com/docs/connect/connect-from-any-app
#
# App (pooled, host com "-pooler"):
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require&connect_timeout=15"
# Prisma CLI migrate/seed (direct, sem "-pooler"):
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require&connect_timeout=15"
#
# Node/Prisma no Windows: NÃO use channel_binding=require na URL
#
# Vercel: configure DATABASE_URL + DIRECT_URL nas env vars do projeto.
# O build NÃO roda migrate (DIRECT_URL usa TCP:5432 e pode falhar com P1001).
# Migrations: npm run db:migrate:deploy (rede com acesso à porta 5432) ou SQL no Neon Console.
# Seed admin: npm run db:seed (funciona via WebSocket com DATABASE_URL pooled).

MP_ACCESS_TOKEN="TEST-xxxxxxxx"
# Vercel: copie o mesmo token em Settings → Environment Variables (Production + Preview)
MP_WEBHOOK_SECRET=""
# URL pública do app (produção). Na Vercel, VERCEL_URL também funciona como fallback.
NEXT_PUBLIC_APP_URL="https://seu-app.vercel.app"
AUTH_SECRET="change-me-in-production"
FOOTBALL_DATA_TOKEN=""
FOOTBALL_DATA_BRAZIL_TEAM_ID="764"
# Minutos antes do início do jogo para encerrar palpites (padrão: 30)
BET_CLOSE_MINUTES_BEFORE="30"
